{
  "name": "@particle-academy/fancy-x-files",
  "version": "0.1.2",
  "description": "Zero-dependency, isomorphic manager for the well-known files every modern web app owes bots and agents — robots.txt, security.txt, llms.txt, humans.txt, sitemap.xml, ai.txt. The Node/TypeScript mirror of the PHP particle-academy/fancy-x-files. Includes a leak-proof robots.txt builder and a default-open RobotsPolicy evaluator.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Particle-Academy/fancy-x-files-js.git"
  },
  "homepage": "https://github.com/Particle-Academy/fancy-x-files-js#readme",
  "bugs": "https://github.com/Particle-Academy/fancy-x-files-js/issues",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist",
    "prepublishOnly": "tsup"
  },
  "keywords": [
    "robots.txt",
    "security.txt",
    "llms.txt",
    "humans.txt",
    "sitemap",
    "ai.txt",
    "well-known",
    "seo",
    "crawlability",
    "agent",
    "fancy",
    "human-plus"
  ],
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.6"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "overrides": {
    "esbuild": "^0.28.1"
  }
}
